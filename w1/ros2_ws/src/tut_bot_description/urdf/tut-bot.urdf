<?xml version="1.0"?>
<robot name="tut-bot">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 1 0.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>


  <link name="front-right-wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
      <material name="black"/>
    </visual>
  </link>

  <link name="front-left-wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
      <material name="black"/>
    </visual>
  </link>

  <link name="back-right-wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
      <material name="black"/>
    </visual>
  </link>

  <link name="back-left-wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin rpy="0 1.57075 0"/>
      <material name="black"/>
    </visual>
  </link>


  <joint name="base-to-fr-wheel" type="fixed">
    <parent link="base_link"/>
    <child link="front-right-wheel"/>
    <origin xyz="0.225 0.5 -0.1"/>
  </joint>

  <joint name="base-to-fl-wheel" type="fixed">
    <parent link="base_link"/>
    <child link="front-left-wheel"/>
    <origin xyz="0.225 -0.5 -0.1"/>
  </joint>

  <joint name="base-to-br-wheel" type="fixed">
    <parent link="base_link"/>
    <child link="back-right-wheel"/>
    <origin xyz="-0.225 0.5 -0.1"/>
  </joint>

  <joint name="base-to-bl-wheel" type="fixed">
    <parent link="base_link"/>
    <child link="back-left-wheel"/>
    <origin xyz="-0.225 -0.5 -0.1"/>
  </joint>

</robot>